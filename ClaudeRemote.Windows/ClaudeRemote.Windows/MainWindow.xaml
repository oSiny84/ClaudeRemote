<Window x:Class="ClaudeRemote.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudeRemote - Windows Controller"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ClaudeRemote" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text=" Controller" FontSize="22" FontWeight="Light"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Status Indicators -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsClaudeConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Claude" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                            <Run Text="Server"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding ConnectedClients, Mode=OneWay}"/>
                            <Run Text=" clients)"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                        <TextBlock Text="IP: " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LocalIpAddress}" Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Controls -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="Connect Claude" Command="{Binding ConnectClaudeCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Port:" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding ServerPort}" Width="70"
                             Style="{StaticResource DarkTextBox}" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Command="{Binding ToggleServerCommand}" Style="{StaticResource PrimaryButton}">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Start Server"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Text" Value="Stop Server"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,2"/>

                <TextBlock Text="Mode: Code" Foreground="{StaticResource PrimaryBrush}"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,2"/>

                <Button Content="Refresh Sessions" Command="{Binding RefreshSessionsCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
                <Button Content="+ Session" Command="{Binding AddSessionCommand}" Style="{StaticResource PrimaryButton}"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,2"/>

                <CheckBox Content="Log to file"
                          IsChecked="{Binding IsLogToFileEnabled}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          VerticalAlignment="Center"
                          ToolTip="Write Serilog output to logs/ folder. Takes effect immediately."/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: Sessions/Projects -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Sessions" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Sessions}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding LastMessage}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2" Text="Projects (Code)" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,8"/>

                    <ListBox Grid.Row="3" ItemsSource="{Binding Projects}" MaxHeight="150"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="13" Margin="4"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Claude Output Display -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Claude Output" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text=" (code mode)"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBox x:Name="ClaudeOutputBox" Grid.Row="1" Text="{Binding ClaudeOutput, Mode=OneWay}"
                             IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource SurfaceLightBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" Padding="12"
                             FontFamily="Consolas" FontSize="13"
                             TextChanged="OutputBox_TextChanged"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,0,0,4">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </Border>

        <!-- Log Area -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Log" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>

                <TextBox x:Name="LogBox" Grid.Row="1" Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource SurfaceLightBrush}"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         BorderThickness="0" Padding="8"
                         FontFamily="Consolas" FontSize="11"
                         TextChanged="OutputBox_TextChanged"/>
            </Grid>
        </Border>
    </Grid>
</Window>
